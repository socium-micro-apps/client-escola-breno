# Para dev local fora do docker, copie para backend/.env e ajuste.
# Em docker-compose, as variáveis vêm do .env raiz + compose env block.

DATABASE_URL=postgresql://admin:admin123@localhost:5432/escola_dev?schema=public

# OBRIGATÓRIO — gere um valor forte: `openssl rand -base64 48`.
# A app falha o boot se este valor estiver vazio ou tiver menos de 16 chars.
JWT_SECRET=

JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5174
LOG_FORMAT=text

SEED_ADMIN_EMAIL=admin@escolabreno.com.br
# OBRIGATÓRIO no primeiro boot — defina uma senha forte aqui antes de subir.
SEED_ADMIN_PASSWORD=
