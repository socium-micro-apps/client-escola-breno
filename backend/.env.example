# Para dev local fora do docker, copie para backend/.env e ajuste.
# Em docker-compose, as variáveis vêm do .env raiz + compose env block.

DATABASE_URL=postgresql://admin:admin123@localhost:5432/escola_dev?schema=public
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5174
LOG_FORMAT=text

SEED_ADMIN_EMAIL=admin@escolabreno.com.br
SEED_ADMIN_PASSWORD=admin123
