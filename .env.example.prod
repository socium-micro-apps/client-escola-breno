# =============================================================================
# .env — escola-breno (produção, em /opt/socium-sf/clients/escola-breno/.env)
# =============================================================================
# Este arquivo é a fonte da verdade do .env.example sincronizado pela pipeline.
# NUNCA commitar valores reais — apenas os nomes / exemplos.
#
# IMAGE_TAG é atualizado automaticamente pelo CI a cada deploy.
# As outras variáveis são editadas UMA vez na VPS pelo operador (depois do
# primeiro deploy criar este .env a partir do exemplo). Deploys subsequentes
# preservam essas edições.
#
# Para dev local (docker compose -f docker-compose.dev.yml up), copie
# .env.example.dev para .env.
# =============================================================================

IMAGE_TAG=latest

# Postgres (container interno, rede 'internal')
POSTGRES_USER=escola
POSTGRES_PASSWORD=GERAR_SENHA_FORTE_AQUI
POSTGRES_DB=escola

# Backend JWT (32+ chars aleatórios; openssl rand -base64 48)
JWT_SECRET=GERAR_SECRET_FORTE_AQUI
JWT_EXPIRES_IN=7d

# Admin seed (apenas para a 1ª subida do banco — depois ignorado por idempotência)
SEED_ADMIN_EMAIL=admin@escolabreno.com.br
SEED_ADMIN_PASSWORD=TROCAR_NA_PRIMEIRA_VEZ
