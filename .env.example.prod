# =============================================================================
# .env — escola-breno (produção, em /opt/socium-sf/clients/escola-breno/.env)
# =============================================================================
# Este arquivo é a fonte da verdade do .env.example sincronizado pela pipeline.
# NUNCA commitar valores reais — apenas os nomes (vazios) ou comentários.
#
# IMAGE_TAG é atualizado automaticamente pelo CI a cada deploy.
# As outras variáveis ABAIXO precisam ser preenchidas pelo operador na VPS
# DEPOIS do primeiro deploy. Sem isso, o backend FALHA O BOOT (proposital —
# evita rodar com placeholders fracos em produção).
#
# Para dev local (docker compose up), use o .env.example da raiz.
# =============================================================================

IMAGE_TAG=latest

# Postgres (container interno, rede 'internal')
POSTGRES_USER=escola
POSTGRES_PASSWORD=
POSTGRES_DB=escola

# Backend JWT (gere com: openssl rand -base64 48)
# Mínimo 16 chars; boot falha se vazio.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Admin seed (usado APENAS na primeira subida do banco para bootstrap).
# A partir do segundo deploy é ignorado: a operação convida admins via /admins.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
