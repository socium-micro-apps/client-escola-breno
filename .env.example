# Copie para .env e ajuste em ambiente local. docker-compose lê esse arquivo.

# Postgres (usado pelo container postgres)
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=escola_dev

# Backend
# Em docker compose, DATABASE_URL aponta para o hostname 'postgres'.
# Em dev local fora do docker, troque para 'localhost'.
DATABASE_URL=postgresql://admin:admin123@postgres:5432/escola_dev?schema=public
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_FORMAT=text

# Admin seed (credenciais iniciais — trocar em produção)
SEED_ADMIN_EMAIL=admin@escolabreno.com.br
SEED_ADMIN_PASSWORD=admin123

# Frontend
VITE_API_URL=http://localhost:3000/api
